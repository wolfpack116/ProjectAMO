limit_req_zone $binary_remote_addr zone=projectamo_api:10m rate=5r/s;

server {
  listen 443 ssl;
  server_name projectamo.co.kr www.projectamo.co.kr;

  ssl_certificate /etc/letsencrypt/live/projectamo.co.kr/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/projectamo.co.kr/privkey.pem;
  include /etc/letsencrypt/options-ssl-nginx.conf;
  ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

  root /opt/projectamo/current/frontend/dist;
  index index.html;

  gzip on;
  gzip_types text/plain text/css application/json application/javascript application/xml+rss image/svg+xml application/geo+json application/topo+json;
  gzip_min_length 1024;

  location /api/ {
    limit_req zone=projectamo_api burst=30 nodelay;

    proxy_pass http://127.0.0.1:3001;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  location /data/ {
    alias /opt/projectamo/shared/data/;
    try_files $uri @projectamo_data_backend;
  }

  location ~* "^/data/(radar/echo_korea_\d{12}\.png|satellite/sat_korea_\d{12}\.(png|webp)|sigwx_low/(fronts|clouds)_\d{10}\.png)$" {
    alias /opt/projectamo/shared/data/$1;
    add_header Cache-Control "public, max-age=10800, immutable";
  }

  location ~* "^/data/(radar/echo_meta\.json|satellite/sat_meta\.json|sigwx_low/(fronts_meta|clouds_meta)_\d{10}\.json)$" {
    alias /opt/projectamo/shared/data/$1;
    add_header Cache-Control "no-cache";
  }

  location ~* "^/(data/navdata/|data/.*\.(geojson|topojson)|Symbols/|assets/)" {
    try_files $uri =404;
    add_header Cache-Control "public, max-age=31536000, immutable";
  }

  location = /index.html {
    try_files $uri =404;
    add_header Cache-Control "no-cache";
  }

  location / {
    try_files $uri /index.html;
  }

  location @projectamo_data_backend {
    proxy_pass http://127.0.0.1:3001;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }
}

server {
  listen 80;
  server_name projectamo.co.kr www.projectamo.co.kr;
  return 301 https://$host$request_uri;
}
