# ProjectAMO 백엔드 환경변수 예시. 실제 값은 .env(커밋 금지)에.

# 세션 서명 시크릿 — 운영 필수. 생성: openssl rand -hex 32
SESSION_SECRET=

# production 이면 쿠키 Secure 강제 + SESSION_SECRET 필수. 개발은 비워두거나 development.
NODE_ENV=development

# 개발용 CORS 허용 origin(프론트 dev 서버). 운영은 nginx 한 origin이라 불필요.
FRONTEND_ORIGIN=http://127.0.0.1:5173

# 데이터/DB 경로(미설정 시 backend/data). projectamo.db 가 여기에 생성됨.
# DATA_PATH=

# #13 경로 예보변화 알림 — 텔레그램 발송(둘 다 있어야 발송, 없으면 인앱 저장만). @BotFather 발급.
# 딥링크는 FRONTEND_ORIGIN/?flight=<id> 사용.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
